%代码注释的颜色
\definecolor{mygreen}{rgb}{0,0.6,0}

\mode<presentation>

% 定义元素基本颜色
\setbeamercolor{structure}{fg=ysublue, bg=}%主颜色。如果没有其他定义，则显示此颜色。
\setbeamercolor{palette primary}{use=structure, fg=ysublue, bg=}

\setbeamercolor{item}{fg=ysublue70}%item的颜色，是70%的燕大蓝。
\setbeamercolor{item projected}{fg=ysublue70}

\setbeamercolor{enumerate item}{fg=black, bg=}
\setbeamercolor{enumerate subitem}{fg=black, bg=}
\setbeamercolor{enumerate subsubitem}{fg=black, bg=}

%默认的标题、副标题、作者、单位、日期，都是白色
\setbeamercolor{title}{fg=white,bg=}
\setbeamercolor{subtitle}{fg=white,bg=}
\setbeamercolor{author}{fg=white,bg=}
\setbeamercolor{date}{fg=white,bg=}

%默认block，颜色是燕大蓝
\setbeamercolor{block title}{bg=ysublue,fg=white}
\setbeamercolor{block body}{bg=ysublue20}

%示例block，颜色是中性灰
\setbeamercolor{block title example}{bg=ysugray,fg=white}
\setbeamercolor{block body example}{bg=ysugray20}

%提示block，颜色是辅助红
\setbeamercolor{block title alerted}{bg=ysured,fg=white}
\setbeamercolor{block body alerted}{bg=ysured20}
